# ═══════════════════════════════════════════════════════════
# NexMedicon HMS — PRODUCTION Environment Variables
# Copy this file to .env.local and fill in ALL values.
# Add these SAME values to Vercel → Project → Settings → Environment Variables
# ═══════════════════════════════════════════════════════════

# ── Supabase (Required) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — needed for admin operations (inviting users, etc.)
# Find in: Supabase → Project Settings → API → service_role key
# ⚠️ NEVER expose this in the browser — server-side only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── AI API Key (Required for OCR/scanning) ───────────────────
# From console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-your-real-key-here
# OR from platform.openai.com → API Keys
# OPENAI_API_KEY=sk-your-openai-key-here

# ── Razorpay (Optional — for online payments) ────────────────
# From dashboard.razorpay.com (use rzp_live_ prefix for production)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_your-key-here
RAZORPAY_KEY_ID=rzp_live_your-key-here
RAZORPAY_KEY_SECRET=your-secret-here

# ── Hospital Config ──────────────────────────────────────────
NEXT_PUBLIC_UPI_ID=yourhospital@upibank
NEXT_PUBLIC_HOSPITAL_NAME=City Women Hospital
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
